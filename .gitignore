# Terraform state — contains real AWS resource IDs, never commit
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# tfvars contains your email — never commit
*.tfvars
!*.tfvars.example

# Lambda deployment package — auto-generated by Terraform
terraform/lambda_function.zip

# Python
__pycache__/
*.pyc
*.pyo
.env

# Test output files
output.json